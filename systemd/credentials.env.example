# AR Audio System - Credentials Template
# Copy this file to /etc/ar_audio/credentials.env and fill in real values.
# Set permissions: sudo chmod 600 /etc/ar_audio/credentials.env
# Set ownership:   sudo chown root:root /etc/ar_audio/credentials.env
#
# DO NOT COMMIT THE REAL credentials.env TO GIT.

# Google Cloud TTS API Key
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_TTS_KEY=your_google_cloud_tts_api_key_here

# OpenAI API Key (used for multilingual translation: ja/en/zh-CN/ko + 8 more)
# Obtain from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
